{
  "name": "raspi-mon-streamdeck",
  "version": "1.0.0",
  "description": "Stream Deck plugin that shows raspi-mon metrics on buttons",
  "author": "sQuarecoW",
  "license": "ISC",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "validate": "streamdeck validate com.squarecow.raspi-mon.sdPlugin",
    "pack": "npm run build && streamdeck pack com.squarecow.raspi-mon.sdPlugin --output dist",
    "restart": "streamdeck restart com.squarecow.raspi-mon"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/node": "^22.9.0",
    "rollup": "^4.27.0",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  }
}
